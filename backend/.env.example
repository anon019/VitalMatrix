# 应用配置
APP_NAME=VitalMatrix
APP_VERSION=0.3.0
DEBUG=True
HOST=0.0.0.0
PORT=8000

# 数据库
DATABASE_URL=postgresql+asyncpg://health_user:your_password@localhost:5432/health_db
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080
# 单用户场景可留空；如果库里出现多个用户，需显式指定默认用户 ID
DEFAULT_USER_ID=

# Polar配置 (训练数据)
POLAR_CLIENT_ID=your_polar_client_id
POLAR_CLIENT_SECRET=your_polar_client_secret
POLAR_REDIRECT_URI=https://your-domain.example.com/api/v1/polar/callback
POLAR_BASE_URL=https://www.polaraccesslink.com/v3

# Oura配置 (睡眠/恢复数据)
OURA_CLIENT_ID=your_oura_client_id
OURA_CLIENT_SECRET=your_oura_client_secret
OURA_REDIRECT_URI=https://your-domain.example.com/api/v1/oura/callback

# AI配置 (主要提供商)
AI_PROVIDER=qwen

# Qwen (通义千问 - 推荐)
QWEN_API_KEY=your_qwen_api_key

# DeepSeek (备选)
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# OpenAI (备选)
OPENAI_API_KEY=

# Claude (备选)
CLAUDE_API_KEY=

# Google Gemini Vision API (营养分析)
GOOGLE_API_KEY=your_google_api_key
GEMINI_VISION_MODEL=gemini-2.5-pro

# OpenRouter 多模型路由平台 (备选 Vision API)
OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_API_BASE=https://openrouter.ai/api/v1
OPENROUTER_VISION_MODEL=google/gemini-3-pro-preview
OPENROUTER_HTTP_REFERER=https://your-domain.example.com
OPENROUTER_APP_TITLE=VitalMatrix

# Vision API 提供商: google 或 openrouter
# google: 直接调用 Google Gemini REST API
# openrouter: 通过 OpenRouter 路由（更稳定）
VISION_API_PROVIDER=openrouter

# 微信小程序
WECHAT_APP_ID=your_wechat_appid
WECHAT_APP_SECRET=your_wechat_secret

# 训练目标配置
TARGET_ZONE2_MIN=55
TARGET_ZONE2_MIN_RANGE=45
TARGET_ZONE2_MAX_RANGE=60
TARGET_HI_MIN=2
TARGET_HI_MIN_RANGE=1
TARGET_HI_MAX_RANGE=5
TARGET_WEEKLY_ZONE2_MIN=200
TARGET_WEEKLY_ZONE2_MAX=300
TARGET_WEEKLY_HI_MAX=30

# 服务器时区（香港时间）
TZ=Asia/Hong_Kong

# 代理配置（腾讯云服务器需要）
NO_PROXY=localhost,127.0.0.1,::1,169.254.0.0/16,.tencentyun.com,*.tencentyun.com

# CORS配置
ALLOWED_ORIGINS=["https://servicewechat.com","https://your-domain.example.com"]

# 日志配置
LOG_LEVEL=INFO

# MCP API配置 (Claude Code 集成)
MCP_API_KEY=your_mcp_api_key
